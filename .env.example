# Beispiel-Konfiguration (kopieren nach .env)

PORT=3001
NODE_ENV=development

# Pflicht in Produktion (langer Zufallsstring)
SESSION_SECRET=change-me-in-production

# SQLite-Datei (Produktion: z. B. persistentes Volume)
DATABASE_PATH=./data/app.db

# Erster Mandant nach leerer Installation (Legacy-Import)
DEFAULT_TENANT_NAME=Mein Unternehmen
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=nimda

# Rechtliche Angaben (Impressum, Datenschutz, AGB): src/legalConfig.js bearbeiten
