# Beispiel-Konfiguration (kopieren nach .env)

PORT=3001
NODE_ENV=development

# Pflicht in Produktion (langer Zufallsstring)
SESSION_SECRET=change-me-in-production

# Datenverzeichnis: SQLite + Mandanten-Assets (Logos) landen hier.
# Produktion (Render): auf die persistente Disk zeigen lassen, z. B. /var/data
DATA_DIR=./data
# Optional: SQLite-Datei explizit überschreiben (sonst DATA_DIR/app.db)
# DATABASE_PATH=./data/app.db

# Erster Mandant nach leerer Installation (Legacy-Import)
DEFAULT_TENANT_NAME=Mein Unternehmen
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=nimda

# E-Mail-Versand (PDF an Kunden)
# Lokal: npm run smtp:setup  (legt Test-SMTP via Ethereal an)
# Produktion: z. B. Brevo — SMTP_HOST=smtp-relay.brevo.com, SMTP_USER=Ihre Login-E-Mail, SMTP_PASS=SMTP-Key
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Rechtliche Angaben (Impressum, Datenschutz, AGB): src/legalConfig.js bearbeiten
